{
  "name": "@ogden/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./scoring": {
      "types": "./src/scoring/index.ts",
      "default": "./src/scoring/index.ts"
    },
    "./manifest": {
      "types": "./src/featureManifest.ts",
      "default": "./src/featureManifest.ts"
    },
    "./demand": {
      "types": "./src/demand/index.ts",
      "default": "./src/demand/index.ts"
    },
    "./relationships": {
      "types": "./src/relationships/index.ts",
      "default": "./src/relationships/index.ts"
    },
    "./regeneration": {
      "types": "./src/regeneration/index.ts",
      "default": "./src/regeneration/index.ts"
    },
    "./evidence": {
      "types": "./src/evidence/index.ts",
      "default": "./src/evidence/index.ts"
    },
    "./fieldVerification": {
      "types": "./src/fieldVerification/index.ts",
      "default": "./src/fieldVerification/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
