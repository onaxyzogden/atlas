{
  "name": "ogden-atlas",
  "private": true,
  "scripts": {
    "dev": "pnpm install && pnpm migrate && turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "migrate": "pnpm --filter @ogden/api migrate",
    "db:studio": "pnpm --filter @ogden/api db:studio"
  },
  "dependencies": {
    "@ogden/ui-components": "github:onaxyzogden/ogden-ui-components#v0.1.0"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
