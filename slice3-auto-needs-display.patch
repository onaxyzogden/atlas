+  font-weight: var(--font-semibold);
+  letter-spacing: 0.06em;
+  text-transform: uppercase;
+  color: var(--color-text-subtle);
+}
+
+/* Bottom tray — open observation needs carousel */
+.bottomTray {
+  display: flex;
+  flex-direction: column;
+  gap: var(--space-3);
+  padding: var(--space-4) var(--space-6);
+  border-top: 1px solid var(--color-border);
+  background: var(--color-chrome-bg-translucent);
+}
+.trayHead {
+  display: flex;
+  align-items: center;
+  gap: var(--space-3);
+  flex-wrap: wrap;
+}
+.trayChip {
+  display: inline-flex;
+  align-items: center;
+  gap: var(--space-2);
+  padding: 2px var(--space-2);
+  border-radius: var(--radius-full);
+  background: var(--color-panel-card);
+  border: 1px solid var(--color-border);
+  font-size: var(--text-xs);
+  color: var(--color-text);
+}
+.trayCount {
+  font-size: var(--text-xs);
+  color: var(--color-text-muted);
+  font-variant-numeric: tabular-nums;
+}
+.traySpacer {
+  flex: 1;
+}
+.carousel {
+  display: flex;
+  gap: var(--space-3);
+  overflow-x: auto;
+  padding-bottom: var(--space-2);
+  scroll-snap-type: x proximity;
+  scrollbar-width: thin;
+}
+.carousel .objCard {
+  min-width: 300px;
+  max-width: 320px;
+  scroll-snap-align: start;
+}
+/* Card footer: Open (always) + Dismiss (auto needs only), right-aligned. */
+.objCardActions {
+  display: flex;
+  align-items: center;
+  justify-content: flex-end;
+  gap: var(--space-2);
+  margin-top: var(--space-1);
+}
+.openBtn {
+  padding: var(--space-1) var(--space-3);
+  border: 1px solid var(--color-border);
+  border-radius: var(--radius-md);
+  background: var(--color-surface);
+  color: var(--color-text);
+  font-size: var(--text-xs);
+  font-weight: var(--font-semibold);
+  cursor: pointer;
+}
+.openBtn:hover {
+  border-color: var(--color-accent);
+}
+/* Ghost button to clear a system-raised need without recording it. */
+.dismissBtn {
+  padding: var(--space-1) var(--space-3);
+  border: 1px solid transparent;
+  border-radius: var(--radius-md);
+  background: transparent;
+  color: var(--color-text-muted);
+  font-size: var(--text-xs);
+  font-weight: var(--font-semibold);
+  cursor: pointer;
+}
+.dismissBtn:hover {
+  color: var(--color-text);
+  border-color: var(--color-border);
+}
+
+/* Narrow viewports: collapse rails to a vertical stack */
+@media (max-width: 1100px) {
+  .body {
+    grid-template-columns: 1fr;
+    overflow-y: auto;
+  }
+  .body[data-sidebar='collapsed'] {
+    grid-template-columns: 1fr;
+  }
+  .sidebar,
+  .rail {
+    border: none;
+    border-bottom: 1px solid var(--color-border);
+  }
+  .mapRegion {
+    min-height: 420px;
+  }
+}
