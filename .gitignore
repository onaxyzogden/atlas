apps/api/data/gaez/cog/*.tiff

# Cesium runtime assets — copied from node_modules/cesium/Build/Cesium at dev
# time so the Vite dev server serves them (viteStaticCopy only fires at build).
# Regenerate with: cp -r node_modules/cesium/Build/Cesium/{Assets,Workers,ThirdParty,Widgets} apps/web/public/cesium/
apps/web/public/cesium/

# Local Claude Code per-project settings (allow-list, MCP creds, etc.)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/
apps/web/.claude/

# Permaculture Scholar / NotebookLM scratch artifacts
.scholar-*

# Scratch/scaffolding directories used while validating data-ingest scripts
apps/api/tmp-*/

# Graphify content-addressed cache (regenerable; not source)
graphify-out/cache/

# Transient typecheck/scratch dumps
_t_*.txt
.graphify_old.json

# Anti-GIS snapshot output (Phase F.1) — keep the dir, ignore the PNGs.
apps/web/screenshots/*.png
