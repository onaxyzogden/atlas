# ── OGDEN Atlas — Production Environment Variables ────────────────────────
# Copy this file to .env.prod and fill in real values.
# NEVER commit .env.prod to version control.

# Domain
DOMAIN=atlas.ogden.ag

# PostgreSQL (internal — not exposed publicly)
POSTGRES_DB=ogden_atlas
POSTGRES_USER=ogden
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password_here

# Redis (internal — not exposed publicly)
REDIS_PASSWORD=CHANGE_ME_another_strong_password

# JWT (minimum 32 characters)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48

# MapTiler (public key for map tiles)
MAPTILER_KEY=your_maptiler_key_here

# Cesium Ion (for 3D terrain visualization)
CESIUM_ION_TOKEN=your_cesium_ion_token_here

# Anthropic (optional — for AI assessment enrichment)
ANTHROPIC_API_KEY=

# S3 / Object Storage (optional)
S3_BUCKET=ogden-atlas-uploads
S3_REGION=us-east-1
S3_ENDPOINT=

# Supabase (optional)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
