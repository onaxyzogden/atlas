    "@ogden/shared": "workspace:*",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.79.0",
    "@turf/turf": "^7.1.0",
    "cesium": "^1.140.0",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.39.0",
    "geotiff": "^3.0.5",
