VITE_MAPTILER_KEY=your_maptiler_key_here
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here
# Demo mode — set to true to auto-register a throwaway guest session on boot,
# bypassing the login gate (used on the live test deployment). Default false.
FEATURE_DEMO_MODE=false

# Client-side telemetry (Act/Observe interaction logs, client error log,
# showcase events). String "true"/"false". When UNSET the default is ON in dev
# (import.meta.env.DEV) and OFF in production builds. Set "false" to silence it
# in dev, or "true" to opt a production build into telemetry.
VITE_ATLAS_TELEMETRY_ENABLED=

# OLOS formal-proof surfaces. String "true" enables; anything else (incl. unset)
# disables. Default off. A localStorage override (key "ogden-flag-olos-formal-proof")
# wins over this at runtime so dev/QA can flip it without a rebuild.
VITE_OLOS_FORMAL_PROOF_ENABLED=
