# ─────────────────────────────────────────────────────────────────────────────
# OGDEN Atlas — API environment (apps/api)
#
# Source of truth: src/lib/config.ts (zod EnvSchema) + the direct process.env
# reads in src/plugins/featureGate.ts and src/services/storage/StorageProvider.ts.
# Keep this file in sync with those — every variable the API reads is listed here.
# Values shown are the schema defaults unless noted; blank = optional/unset.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://ogden_app:ogden_dev_password@localhost:5432/ogden_atlas
REDIS_URL=redis://localhost:6379
# Min 32 chars. In production Render generates this (render.yaml generateValue).
JWT_SECRET=change-this-to-a-32-character-minimum-secret-key

# ── CORS + rate limiting ─────────────────────────────────────────────────────
# Comma-separated allowed origins. Defaults cover both local dev apps (web 5200,
# a second surface 5300). Set exactly in production (e.g. https://atlas.ogden.ag).
CORS_ORIGIN=http://localhost:5200,http://localhost:5300
# Global authenticated-route rate limit.
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=1 minute
# Reverse-proxy hop count — makes the per-IP portal limits below REAL behind a
# proxy. Unset/empty = trust nobody (correct for local dev: the socket peer IS
# the client). Behind a proxy this MUST be set or every visitor shares one IP
# bucket. A number = trusted hops nearest the server; 'true' = trust whole XFF
# chain (spoofable); a comma-list = trusted subnets/IPs. On Render the chain is
# client → Render edge → nginx → api, so production uses "2" (see render.yaml).
TRUST_PROXY=

# ── Public portal (UNAUTHENTICATED) per-IP rate limits, fixed 1-minute window ─
# Tighter than the global limit: these are the only routes reachable without a
# JWT. PDF cap is lower — each hit streams a multi-MB binary.
PORTAL_PUBLIC_RATE_LIMIT_MAX=60
PORTAL_PDF_RATE_LIMIT_MAX=10

# ── Email (verification + password reset) ────────────────────────────────────
# 'console' (default) logs links to stdout, no account needed.
# 'resend' sends real mail via the Resend REST API (needs RESEND_API_KEY; a
# missing key falls back to console with a warning, never blocks boot).
EMAIL_TRANSPORT=console
RESEND_API_KEY=
EMAIL_FROM=OGDEN Atlas <noreply@ogden.ag>
# Base URL used to build verify/reset links in emails.
APP_PUBLIC_URL=http://localhost:5200

# ── Model provider (optional) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── PDF rendering (optional) ─────────────────────────────────────────────────
# Path to a Chromium/Chrome binary for the portal PDF route. Leave unset to use
# the bundled/puppeteer-resolved binary.
# PUPPETEER_EXECUTABLE_PATH=

# ── Object storage (proof photos / exports) ──────────────────────────────────
# Leave S3_BUCKET unset to use local ephemeral disk. AWS credentials are resolved
# by the AWS SDK default chain — set AWS_ACCESS_KEY_ID / AWS_PROFILE (read in
# services/storage/StorageProvider.ts) or rely on instance/role creds.
S3_BUCKET=ogden-atlas-uploads
S3_REGION=us-east-1
S3_ENDPOINT=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_PROFILE=
# Supabase Storage (optional alternative to raw S3 — direct JWT above works without it)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── GAEZ v4 self-hosted rasters (optional — layer disabled if data dir empty) ─
# Local FS path relative to apps/api cwd, or absolute. Leave as default for dev.
GAEZ_DATA_DIR=./data/gaez/cog
# Set to a public HTTPS base URL (or S3 byte-range prefix) to serve COGs remotely.
# GAEZ_S3_PREFIX=https://ogden-atlas-geodata.s3.us-east-1.amazonaws.com/gaez/v4/

# ── SoilGrids v2.0 self-hosted rasters (optional) ────────────────────────────
SOILGRIDS_DATA_DIR=./data/soilgrids/cog
# SOILGRIDS_S3_PREFIX=https://ogden-atlas-geodata.s3.us-east-1.amazonaws.com/soilgrids/v2/

# ── Placement guard (design-features PostGIS validation) ─────────────────────
# off | log | enforce. Default 'log' = evaluate + log violations, never reject
# (legacy rows synced before the rules existed must not brick sync).
PLACEMENT_GUARD_MODE=log

# ── Phase / feature gating (read directly in plugins/featureGate.ts) ─────────
# ATLAS_PHASE_MAX — highest phase tag whose routes are reachable: P1 | P2 | P3 |
#   P4 (default P4 = everything). Routes above the ceiling return 404 (existence
#   not leaked).
ATLAS_PHASE_MAX=P4
# ATLAS_MOONTRANCE — '1' or 'true' opens MT-tagged routes regardless of the
#   P-tag ceiling; otherwise they 404. Default off.
ATLAS_MOONTRANCE=
# ATLAS_LATENT — '1' or 'true' opens latent-tagged routes. ATLAS_FUTURE is the
#   honoured legacy name (pre ADR 2026-05-02 D2). Default off.
ATLAS_LATENT=
