NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://ogden_app:CHANGE_ME@localhost:5432/ogden_atlas
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-this-to-a-32-character-minimum-secret-key

# Supabase (optional for local dev — use direct JWT above instead)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# S3 / Supabase Storage
S3_BUCKET=ogden-atlas-uploads
S3_REGION=us-east-1
S3_ENDPOINT=

# GAEZ v4 self-hosted rasters (optional — layer disabled if data dir empty)
# Local FS path relative to apps/api cwd, or absolute. Leave as default for dev.
GAEZ_DATA_DIR=./data/gaez/cog
# Set to a public HTTPS base URL (or S3 signed-URL prefix) to serve COGs via byte-range reads.
# GAEZ_S3_PREFIX=https://ogden-atlas-geodata.s3.us-east-1.amazonaws.com/gaez/v4/

# Feature flags (Phase 2+)
FEATURE_TERRAIN_3D=false
FEATURE_HYDROLOGY=false
FEATURE_LIVESTOCK=false
FEATURE_AI=false
FEATURE_MULTI_USER=true
FEATURE_OFFLINE=false
FEATURE_SCENARIOS=false
FEATURE_PUBLIC_PORTAL=false
